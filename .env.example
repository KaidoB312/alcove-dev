# ============================================
# LOCAL EXPRESS SERVER (server.js)
# ============================================
DB_HOST=your_host
DB_PORT=3306
DB_NAME=alcove_db
DB_USER=root
DB_PASS=your_password

# ============================================
# EXPRESS AUTH (server.js - uses bcrypt)
# ============================================
ADMIN_PASSWORD_HASH=<bcrypt-hash>
SESSION_SECRET=<random-string>
PORT=3000

# ============================================
# CLOUDFLARE PAGES ENVIRONMENT VARIABLES
# ============================================
# Set these in Cloudflare Pages Dashboard > Settings > Environment variables.
#
# ADMIN_PASSWORD_HASH  - SHA-256 hex digest of your admin password
#   Generate with: node -e "const crypto=require('crypto');console.log(crypto.createHash('sha256').update('yourpassword').digest('hex'))"
#
# SESSION_SECRET       - Random string for JWT signing
#   Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
