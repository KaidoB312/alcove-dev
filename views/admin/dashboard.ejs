<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard · Alcove</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .admin-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }
        .stat-card {
            background: white;
            border: 1px solid #e0dbcf;
            border-radius: 1rem;
            padding: 1.5rem;
            text-align: center;
        }
        .stat-number {
            font-size: 3rem;
            font-weight: 700;
            font-family: 'Space Mono', monospace;
            color: #c2a25b;
        }
        .stat-label {
            font-size: 1rem;
            color: #5f5d59;
        }
        .action-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            justify-content: center;
            margin: 2rem 0;
        }
        .action-buttons a {
            min-width: 180px;
        }
        .recent-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin: 2rem 0;
        }
        .recent-card {
            background: white;
            border: 1px solid #e0dbcf;
            border-radius: 1rem;
            padding: 1rem;
        }
        .recent-card h3 {
            font-size: 1.2rem;
            margin-bottom: 1rem;
        }
        .recent-list {
            list-style: none;
            padding: 0;
        }
        .recent-list li {
            border-bottom: 1px solid #e0dbcf;
            padding: 0.5rem 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .recent-list a {
            text-decoration: none;
            color: #2b2a28;
        }
        .recent-list a:hover {
            color: #c2a25b;
        }
        .recent-date {
            font-size: 0.7rem;
            color: #5f5d59;
        }
        .btn-sm {
            padding: 0.3rem 0.8rem;
            font-size: 0.8rem;
        }
        .admin-nav {
            margin: 2rem 0;
            text-align: right;
        }
        .admin-nav a {
            margin-left: 1rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="admin-nav">
            <a href="/admin/logout" class="btn secondary">Logout</a>
            <a href="/" class="btn secondary">View Site</a>
        </div>
        <div class="admin-container">
            <h1>Admin Dashboard</h1>

            <!-- Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-number"><%= memberCount %></div>
                    <div class="stat-label">Team Members</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number"><%= projectCount %></div>
                    <div class="stat-label">Projects</div>
                </div>
            </div>

            <!-- Main management buttons -->
            <div class="action-buttons">
                <a href="/admin/members" class="btn primary">Manage Members</a>
                <a href="/admin/projects" class="btn primary">Manage Projects</a>
            </div>

            <!-- Quick add buttons -->
            <div class="action-buttons">
                <a href="/admin/members/add" class="btn secondary">+ Add New Member</a>
                <a href="/admin/projects/add" class="btn secondary">+ Add New Project</a>
            </div>

            <!-- Recent Activity -->
            <div class="recent-section">
                <div class="recent-card">
                    <h3>Recent Members</h3>
                    <ul class="recent-list">
                        <% if (recentMembers.length) { %>
                            <% recentMembers.forEach(member => { %>
                                <li>
                                    <a href="/admin/members/edit/<%= member.id %>"><%= member.name %></a>
                                    <span class="recent-date"><%= member.created_at.toISOString().slice(0,10) %></span>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li>No members yet.</li>
                        <% } %>
                    </ul>
                </div>
                <div class="recent-card">
                    <h3>Recent Projects</h3>
                    <ul class="recent-list">
                        <% if (recentProjects.length) { %>
                            <% recentProjects.forEach(project => { %>
                                <li>
                                    <a href="/admin/projects/edit/<%= project.id %>"><%= project.title %></a>
                                    <span class="recent-date"><%= project.created_at.toISOString().slice(0,10) %></span>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li>No projects yet.</li>
                        <% } %>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</body>
</html>