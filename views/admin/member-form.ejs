<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= member ? 'Edit' : 'Add' %> Member · Alcove Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .form-container {
            max-width: 800px;
            margin: 2rem auto;
            background: white;
            border-radius: 1rem;
            padding: 2rem;
            border: 1px solid #e0dbcf;
        }
        label {
            display: block;
            margin: 1rem 0 0.3rem;
            font-weight: 500;
        }
        input, textarea {
            width: 100%;
            padding: 0.6rem;
            border: 1px solid #e0dbcf;
            border-radius: 0.5rem;
            font-family: inherit;
        }
        .dynamic-group {
            margin: 1rem 0;
            padding: 0.5rem;
            border: 1px solid #e0dbcf;
            border-radius: 0.5rem;
        }
        .dynamic-item {
            display: flex;
            gap: 0.5rem;
            align-items: flex-start;
            margin-bottom: 0.5rem;
        }
        .dynamic-item input, .dynamic-item textarea {
            flex: 1;
        }
        .dynamic-item button {
            margin-top: 0;
            padding: 0.3rem 0.6rem;
            background: #e67e22;
            color: white;
            border: none;
            border-radius: 0.3rem;
            cursor: pointer;
        }
        .add-btn {
            margin-top: 0.5rem;
            padding: 0.3rem 0.8rem;
            background: #2c5f2d;
            color: white;
            border: none;
            border-radius: 0.3rem;
            cursor: pointer;
        }
        .note {
            font-size: 0.8rem;
            color: #5f5d59;
            margin-top: 0.3rem;
        }
        hr {
            margin: 1rem 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="form-container">
            <h1><%= member ? 'Edit' : 'Add New' %> Member</h1>
            <% if (locals.error) { %>
                <p style="color:#c2a25b;"><%= error %></p>
            <% } %>
            <form method="POST" action="/admin/members/save" id="memberForm">
                <% if (member && member.id) { %>
                    <input type="hidden" name="id" value="<%= member.id %>">
                <% } %>

                <label>Slug (unique, e.g., "kaido") *</label>
                <input type="text" name="slug" value="<%= member ? member.slug : '' %>" required>
                <div class="note">Used in URL: /:slug</div>

                <label>Name *</label>
                <input type="text" name="name" value="<%= member ? member.name : '' %>" required>

                <label>Role</label>
                <input type="text" name="role" value="<%= member ? member.role : '' %>">

                <label>Experience Years (integer)</label>
                <input type="number" name="experience_years" value="<%= member ? member.experience_years : '' %>">

                <label>Bio (short intro)</label>
                <textarea name="bio"><%= member ? member.bio : '' %></textarea>

                <label>Email</label>
                <input type="email" name="email" value="<%= member ? member.email : '' %>">

                <label>Discord (full link or username)</label>
                <input type="text" name="discord" value="<%= member ? member.discord : '' %>">

                <hr>

                <!-- Skills -->
                <div class="dynamic-group">
                    <label>Skills</label>
                    <div id="skillsContainer">
                        <% if (member && member.skills) { 
                            const skills = typeof member.skills === 'string' ? JSON.parse(member.skills) : member.skills;
                            skills.forEach((skill, idx) => { %>
                                <div class="dynamic-item">
                                    <input type="text" placeholder="Skill name" class="skill-name" value="<%= skill.name %>">
                                    <input type="number" placeholder="Percent" class="skill-percent" value="<%= skill.percent %>">
                                    <input type="text" placeholder="Tags (comma separated)" class="skill-tags" value="<%= skill.tags ? skill.tags.join(', ') : '' %>">
                                    <button type="button" class="remove-btn">✕</button>
                                </div>
                        <% }) } else { %>
                            <div class="dynamic-item">
                                <input type="text" placeholder="Skill name" class="skill-name">
                                <input type="number" placeholder="Percent" class="skill-percent">
                                <input type="text" placeholder="Tags (comma separated)" class="skill-tags">
                                <button type="button" class="remove-btn">✕</button>
                            </div>
                        <% } %>
                    </div>
                    <button type="button" class="add-btn" id="addSkill">+ Add Skill</button>
                </div>

                <!-- Certifications -->
                <div class="dynamic-group">
                    <label>Certifications</label>
                    <div id="certsContainer">
                        <% if (member && member.certifications) {
                            const certs = typeof member.certifications === 'string' ? JSON.parse(member.certifications) : member.certifications;
                            certs.forEach(cert => { %>
                                <div class="dynamic-item">
                                    <input type="text" placeholder="Certification name" class="cert-name" value="<%= cert %>">
                                    <button type="button" class="remove-btn">✕</button>
                                </div>
                        <% }) } else { %>
                            <div class="dynamic-item">
                                <input type="text" placeholder="Certification name" class="cert-name">
                                <button type="button" class="remove-btn">✕</button>
                            </div>
                        <% } %>
                    </div>
                    <button type="button" class="add-btn" id="addCert">+ Add Certification</button>
                </div>

                <!-- Offerings -->
                <div class="dynamic-group">
                    <label>Offerings (services)</label>
                    <div id="offeringsContainer">
                        <% if (member && member.offerings) {
                            const offerings = typeof member.offerings === 'string' ? JSON.parse(member.offerings) : member.offerings;
                            offerings.forEach(offering => { %>
                                <div class="dynamic-item">
                                    <input type="text" placeholder="Title" class="offering-title" value="<%= offering.title %>">
                                    <textarea placeholder="Description" class="offering-desc" rows="2"><%= offering.desc %></textarea>
                                    <input type="text" placeholder="Icon (e.g., 'server')" class="offering-icon" value="<%= offering.icon %>">
                                    <button type="button" class="remove-btn">✕</button>
                                </div>
                        <% }) } else { %>
                            <div class="dynamic-item">
                                <input type="text" placeholder="Title" class="offering-title">
                                <textarea placeholder="Description" class="offering-desc" rows="2"></textarea>
                                <input type="text" placeholder="Icon (e.g., 'server')" class="offering-icon">
                                <button type="button" class="remove-btn">✕</button>
                            </div>
                        <% } %>
                    </div>
                    <button type="button" class="add-btn" id="addOffering">+ Add Offering</button>
                </div>

                <hr>

                <button type="submit" class="btn primary">Save Member</button>
                <a href="/admin/members" class="btn secondary">Cancel</a>
            </form>
        </div>
    </div>

    <script>
        // Helper to collect data from dynamic fields
        function buildJSON() {
            const skills = [];
            document.querySelectorAll('#skillsContainer .dynamic-item').forEach(item => {
                const name = item.querySelector('.skill-name')?.value.trim();
                if (name) {
                    const percent = parseInt(item.querySelector('.skill-percent')?.value);
                    const tags = item.querySelector('.skill-tags')?.value.split(',').map(t => t.trim()).filter(t => t);
                    skills.push({ name, percent: isNaN(percent) ? null : percent, tags });
                }
            });

            const certifications = [];
            document.querySelectorAll('#certsContainer .dynamic-item').forEach(item => {
                const name = item.querySelector('.cert-name')?.value.trim();
                if (name) certifications.push(name);
            });

            const offerings = [];
            document.querySelectorAll('#offeringsContainer .dynamic-item').forEach(item => {
                const title = item.querySelector('.offering-title')?.value.trim();
                if (title) {
                    const desc = item.querySelector('.offering-desc')?.value.trim();
                    const icon = item.querySelector('.offering-icon')?.value.trim();
                    offerings.push({ title, desc, icon });
                }
            });

            // Create hidden inputs to send JSON strings
            document.getElementById('skillsJson')?.remove();
            document.getElementById('certsJson')?.remove();
            document.getElementById('offeringsJson')?.remove();

            const skillsInput = document.createElement('input');
            skillsInput.type = 'hidden';
            skillsInput.name = 'skills';
            skillsInput.id = 'skillsJson';
            skillsInput.value = JSON.stringify(skills);
            document.getElementById('memberForm').appendChild(skillsInput);

            const certsInput = document.createElement('input');
            certsInput.type = 'hidden';
            certsInput.name = 'certifications';
            certsInput.id = 'certsJson';
            certsInput.value = JSON.stringify(certifications);
            document.getElementById('memberForm').appendChild(certsInput);

            const offeringsInput = document.createElement('input');
            offeringsInput.type = 'hidden';
            offeringsInput.name = 'offerings';
            offeringsInput.id = 'offeringsJson';
            offeringsInput.value = JSON.stringify(offerings);
            document.getElementById('memberForm').appendChild(offeringsInput);
        }

        // Add/remove dynamic items
        function addSkill() {
            const container = document.getElementById('skillsContainer');
            const div = document.createElement('div');
            div.className = 'dynamic-item';
            div.innerHTML = `
                <input type="text" placeholder="Skill name" class="skill-name">
                <input type="number" placeholder="Percent" class="skill-percent">
                <input type="text" placeholder="Tags (comma separated)" class="skill-tags">
                <button type="button" class="remove-btn">✕</button>
            `;
            container.appendChild(div);
            div.querySelector('.remove-btn').addEventListener('click', () => div.remove());
        }

        function addCert() {
            const container = document.getElementById('certsContainer');
            const div = document.createElement('div');
            div.className = 'dynamic-item';
            div.innerHTML = `
                <input type="text" placeholder="Certification name" class="cert-name">
                <button type="button" class="remove-btn">✕</button>
            `;
            container.appendChild(div);
            div.querySelector('.remove-btn').addEventListener('click', () => div.remove());
        }

        function addOffering() {
            const container = document.getElementById('offeringsContainer');
            const div = document.createElement('div');
            div.className = 'dynamic-item';
            div.innerHTML = `
                <input type="text" placeholder="Title" class="offering-title">
                <textarea placeholder="Description" class="offering-desc" rows="2"></textarea>
                <input type="text" placeholder="Icon (e.g., 'server')" class="offering-icon">
                <button type="button" class="remove-btn">✕</button>
            `;
            container.appendChild(div);
            div.querySelector('.remove-btn').addEventListener('click', () => div.remove());
        }

        document.getElementById('addSkill').addEventListener('click', addSkill);
        document.getElementById('addCert').addEventListener('click', addCert);
        document.getElementById('addOffering').addEventListener('click', addOffering);

        // Add remove listeners for existing items
        document.querySelectorAll('.remove-btn').forEach(btn => {
            btn.addEventListener('click', () => btn.closest('.dynamic-item').remove());
        });

        // Before submit, build the JSON hidden fields
        document.getElementById('memberForm').addEventListener('submit', (e) => {
            buildJSON();
            // The form will now submit with the hidden inputs containing JSON
        });
    </script>
</body>
</html>