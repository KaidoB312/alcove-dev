<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Projects · Alcove Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .admin-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }
        .admin-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 1rem;
            overflow: hidden;
            margin: 1rem 0;
        }
        .admin-table th, .admin-table td {
            padding: 1rem;
            text-align: left;
            border-bottom: 1px solid #e0dbcf;
        }
        .admin-table th {
            background: #f0ede6;
            font-weight: 600;
        }
        .actions a {
            margin-right: 0.5rem;
        }
        .btn-sm {
            padding: 0.3rem 0.8rem;
            font-size: 0.8rem;
        }
        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="admin-header">
            <h1>Manage Projects</h1>
            <a href="/admin/projects/add" class="btn primary">+ Add New Project</a>
        </div>
        <div>
            <a href="/admin/dashboard" class="btn secondary btn-sm">← Back to Dashboard</a>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (projects && projects.length) { %>
                    <% projects.forEach(project => { %>
                        <tr>
                            <td><%= project.id %></td>
                            <td><%= project.title %></td>
                            <td><%= project.description.substring(0, 100) %><%= project.description.length > 100 ? '...' : '' %></td>
                            <td class="actions">
                                <a href="/admin/projects/edit/<%= project.id %>" class="btn secondary btn-sm">Edit</a>
                                <a href="/admin/projects/delete/<%= project.id %>" class="btn secondary btn-sm" onclick="return confirm('Delete this project?');">Delete</a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" style="text-align:center;">No projects yet. Click "Add New Project" to create one.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html>