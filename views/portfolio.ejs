<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio · Alcove</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
        <style>
        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin: 3rem 0;
        }
        .portfolio-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 1.5rem;
            padding: 2rem;
            text-align: center;
            transition: 0.2s;
        }
        .portfolio-card:hover {
            transform: translateY(-4px);
            border-color: var(--accent);
        }
        .portfolio-icon {
            font-size: 3rem;
            color: var(--accent);
            margin-bottom: 1rem;
        }
        .portfolio-card h2 {
            margin: 0 0 1rem;
            border: none;
            padding: 0;
        }
        .portfolio-card p {
            color: var(--text-muted);
            margin-bottom: 1.5rem;
        }
        .portfolio-link {
            display: inline-block;
            background: var(--btn-primary-bg);
            color: var(--btn-primary-text);
            padding: 0.6rem 1.2rem;
            border-radius: 2rem;
            text-decoration: none;
            font-size: 0.9rem;
            transition: 0.2s;
        }
        .portfolio-link:hover {
            background: var(--accent);
            color: var(--btn-primary-text);
        }
    </style>
</head>
<body>
    <div class="container">
        <nav class="navbar">
            <div class="logo">
                <span class="mono">[</span> The Alcove <span class="mono">]</span>
            </div>
            <button class="menu-toggle" aria-label="Toggle navigation">
                <span></span><span></span><span></span>
            </button>
            <div class="nav-links">
                <a href="/">home</a>
                <a href="/portfolio" class="active">portfolio</a>
                <a href="/projects">projects</a>
                <a href="/#contact">contact</a>
            </div>
            <button id="darkModeToggle" class="dark-mode-toggle" aria-label="Toggle dark mode">
                <i class="fas fa-moon"></i>
            </button>
        </nav>

        <section class="hero" style="margin-bottom: 0;">
            <div class="hero-content">
                <span class="badge">// meet the team</span>
                <h1>portfolio &<br>resumes.</h1>
                <p>Get to know the people behind the code – their skills, experience, and projects.</p>
            </div>
        </section>

        <div class="portfolio-grid">
            <% members.forEach(member => { %>
                <div class="portfolio-card">
                    <div class="portfolio-icon">
                        <i class="fas <%= member.slug === 'kaido' ? 'fa-terminal' : member.slug === 'cams' ? 'fa-users' : 'fa-user' %>"></i>
                    </div>
                    <h2><%= member.name %></h2>
                    <p><%= member.role %></p>
                    <p><%= member.bio.substring(0, 120) %>...</p>
                    <a href="/<%= member.slug %>" class="portfolio-link">view resume →</a>
                </div>
            <% }) %>
        </div>

        <footer>
            <p>© 2025 alcove – quiet, intentional development.</p>
        </footer>
    </div>
    <script src="/script.js"></script>
    <script src="/dark.js"></script>
</body>
</html>