<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projects · Alcove</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }
        .project-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 1rem;
            padding: 1rem;
        }
        .project-tag {
            display: inline-block;
            background: var(--tag-bg);
            font-size: 0.7rem;
            padding: 0.2rem 0.6rem;
            border-radius: 1rem;
            margin: 0.5rem 0;
            color: var(--text-muted);
        }
        .project-tag.duration {
            background: var(--progress-bg);
        }
    </style>
</head>
<body>
    <div class="container">
        <nav class="navbar">
            <div class="logo">
                <span class="mono">[</span> The Alcove <span class="mono">]</span>
            </div>
            <button class="menu-toggle" aria-label="Toggle navigation">
                <span></span><span></span><span></span>
            </button>
            <div class="nav-links">
                <a href="/">home</a>
                <a href="/portfolio">portfolio</a>
                <a href="/projects" class="active">projects</a>
                <a href="/#contact">contact</a>
            </div>
            <button id="darkModeToggle" class="dark-mode-toggle" aria-label="Toggle dark mode">
                <i class="fas fa-moon"></i>
            </button>
        </nav>

        <section class="hero" style="margin-bottom: 0;">
            <div class="hero-content">
                <span class="badge">// our work</span>
                <h1>projects.</h1>
                <p>A selection of the things we've built, together and individually.</p>
            </div>
        </section>

        <div class="projects-grid">
            <% if (projects && projects.length) { %>
                <% projects.forEach(proj => { %>
                    <div class="project-card">
                        <h3><%= proj.name %></h3>
                        <div class="project-tags">
                            <% if (proj.contributorDetails && proj.contributorDetails.length) { %>
                                <% proj.contributorDetails.forEach(contrib => { %>
                                    <div class="project-tag"><%= contrib.member_slug.charAt(0).toUpperCase() + contrib.member_slug.slice(1) %>: <%= contrib.tag %></div>
                                <% }) %>
                            <% } %>
                        </div>
                        <p><%= proj.description %></p>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No projects yet.</p>
            <% } %>
        </div>

        <footer>
            <p>© 2026 The Alcove – quiet, intentional development.</p>
        </footer>
    </div>
    <a href="/admin/login" class="admin-badge"><i class="fas fa-lock"></i> admin</a>
    <script src="/script.js"></script>
    <script src="/dark.js"></script>
</body>
</html>