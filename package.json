{
  "name": "alcove-dev",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "vite",
    "pages:deploy": "wrangler pages deploy dist",
    "db:migrate": "wrangler d1 execute alcove-db --file=./migrations/0001_initial.sql",
    "db:migrate:prod": "wrangler d1 execute alcove-db --remote --file=./migrations/0001_initial.sql",
    "db:seed": "wrangler d1 execute alcove-db --file=./scripts/seed.sql",
    "db:seed:prod": "wrangler d1 execute alcove-db --remote --file=./scripts/seed.sql"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0"
  }
}
